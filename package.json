{
  "name": "colortxt",
  "private": true,
  "version": "2.6.5",
  "description": "一款会给内容上色的本地 TXT 小说阅读器，带给你不一样的阅读体验！",
  "type": "module",
  "main": "dist/main/index.js",
  "author": "kainanhong@gmail.com",
  "homepage": "https://github.com/ssnangua/ColorTxt",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-rebuild -f -w better-sqlite3,opencc && node scripts/prune-pack-deps.mjs && electron-builder --publish never",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "echo \"(no lint configured)\"",
    "release": "electron-vite build && electron-rebuild -f -w better-sqlite3,opencc && node scripts/prune-pack-deps.mjs && electron-builder --publish always",
    "postinstall": "electron-rebuild -f -w better-sqlite3,opencc && node scripts/patch-nested-sharp-stub.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@node-rs/jieba": "^2.0.1",
    "better-sqlite3": "^11.7.0",
    "electron-updater": "^6.8.3",
    "font-list": "^2.0.2",
    "iconv-lite": "^0.7.2",
    "opencc": "^1.3.1",
    "sharp": "file:scripts/sharp-pack-stub",
    "sqlite-vec": "^0.1.6",
    "ws": "^8.18.0"
  },
  "overrides": {
    "sharp": "file:scripts/sharp-pack-stub",
    "@huggingface/transformers": {
      "sharp": "file:scripts/sharp-pack-stub"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-cloud": "^1.2.9",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/pako": "^2.0.4",
    "@types/sortablejs": "^1.15.9",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-vue": "^5.2.3",
    "d3-cloud": "^1.2.7",
    "d3-scale": "^4.0.2",
    "electron": "^35.1.4",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.0.0",
    "jschardet": "^3.1.4",
    "jszip": "^3.10.1",
    "katex": "^0.16.22",
    "marked": "^14.1.3",
    "marked-katex-extension": "^5.1.8",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "monaco-editor": "^0.55.1",
    "pako": "^2.1.0",
    "pdfjs-dist": "^5.6.205",
    "sortablejs": "^1.15.7",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vue": "^3.5.31",
    "vue-tsc": "^2.2.8"
  },
  "build": {
    "appId": "com.ssnangua.colortxt",
    "productName": "彩读",
    "beforePack": "scripts/electron-before-pack.mjs",
    "onNodeModuleFile": "scripts/electron-on-node-module-file.mjs",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/sqlite-vec/**",
      "**/node_modules/sqlite-vec-*/**",
      "**/node_modules/onnxruntime-node/bin/**",
      "**/node_modules/@node-rs/jieba/**",
      "**/node_modules/@node-rs/jieba-*/**",
      "**/node_modules/opencc/**"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      }
    ],
    "files": [
      "dist/**",
      "package.json",
      "node_modules/sharp/**"
    ],
    "electronLanguages": [
      "en-US",
      "zh-CN",
      "zh-TW"
    ],
    "fileAssociations": [
      {
        "ext": "txt",
        "name": "Text Document",
        "description": "纯文本文件",
        "mimeType": "text/plain",
        "role": "Editor"
      }
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "artifactName": "${name}-${version}-${arch}.${ext}",
      "publish": {
        "provider": "github",
        "owner": "ssnangua",
        "repo": "ColorTxt",
        "channel": "latest-${arch}"
      },
      "target": [
        "dmg"
      ],
      "electronLanguages": [
        "en",
        "en_GB",
        "zh_CN",
        "zh_TW"
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "artifactName": "${name}-${version}.${ext}",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${name}-${version}-Portable.${ext}"
    },
    "nsis": {
      "artifactName": "${name}-${version}-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "resources/icon.png",
      "artifactName": "${name}-${version}-${arch}.${ext}",
      "publish": {
        "provider": "github",
        "owner": "ssnangua",
        "repo": "ColorTxt",
        "channel": "latest-${arch}"
      },
      "target": [
        "AppImage"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "ssnangua",
      "repo": "ColorTxt"
    }
  }
}
